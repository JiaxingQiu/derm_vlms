# Copy this file to .env.production and fill in real values.
# This file is loaded by revlm_dc/settings.py and by systemd via EnvironmentFile.

DJANGO_SECRET_KEY=replace-with-a-strong-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional path overrides
DJANGO_STATIC_ROOT=/home/azureuser/derm_vlms/revlm_dc/staticfiles
DJANGO_MEDIA_ROOT=/home/azureuser/derm_vlms/revlm_dc/images

# Optional security overrides (defaults are secure in production)
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True

# Database options:
# 1) Keep SQLite (default) by leaving these unset.
# 2) Use Azure PostgreSQL with either DATABASE_URL or discrete vars below.

# Example DATABASE_URL format:
# DATABASE_URL=postgresql://dbuser:dbpassword@your-server.postgres.database.azure.com:5432/your_db_name

# Or use discrete variables instead of DATABASE_URL:
# DJANGO_DB_ENGINE=postgresql
# DJANGO_DB_NAME=your_db_name
# DJANGO_DB_USER=dbuser
# DJANGO_DB_PASSWORD=dbpassword
# DJANGO_DB_PASSWORD_COMMAND=/usr/bin/az account get-access-token --resource https://ossrdbms-aad.database.windows.net --query accessToken --output tsv
# DJANGO_DB_HOST=your-server.postgres.database.azure.com
# DJANGO_DB_PORT=5432
# DJANGO_DB_SSLMODE=require
