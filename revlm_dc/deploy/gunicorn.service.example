[Unit]
Description=Gunicorn service for revlm_dc Django project
After=network.target

[Service]
User=azureuser
Group=www-data
WorkingDirectory=/home/azureuser/derm_vlms/revlm_dc
Environment="PATH=/home/azureuser/miniconda3/envs/derm_django_env/bin:/usr/bin:/bin"
Environment="DJANGO_SETTINGS_MODULE=revlm_dc.settings"
Environment="DJANGO_ENV_FILE=/home/azureuser/derm_vlms/revlm_dc/.env.production"
EnvironmentFile=/home/azureuser/derm_vlms/revlm_dc/.env.production
ExecStart=/home/azureuser/miniconda3/envs/derm_django_env/bin/gunicorn --workers 1 --bind 127.0.0.1:8000 revlm_dc.wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
